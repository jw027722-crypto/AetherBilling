PORT=5000
STRIPE_PLATFORM_SECRET_KEY=sk_test_your_platform_secret_key
STRIPE_PLATFORM_PUBLIC_KEY=pk_test_your_platform_publishable_key
AETHER_INTERNAL_SECRET=replace_with_a_long_random_shared_secret
STRIPE_CLIENT_ID=ca_your_stripe_connect_client_id
AETHER_ALLOWED_ORIGIN=https://your-wordpress-site.example
NODE_BASE_URL=https://billing.aetherframeworks.dev
# Match your Stripe account default (e.g. eur, usd)
STRIPE_DEFAULT_CURRENCY=eur
STRIPE_DEFAULT_COUNTRY=IE
